# Copy this file to .env and fill in your values. Never commit .env anywhere.

# --- Reddit API (script app, read-only) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=macos:state-civic-listener:v1.0 (by /u/YOUR_REDDIT_USERNAME)

# --- OpenRouter ---
OPENROUTER_API_KEY=
# Free models change weekly. Run scripts/pick_model.py (or see README) to re-check.
CLASSIFIER_MODEL=deepseek/deepseek-chat:free
CLASSIFIER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Apify (Facebook public groups, free tier) ---
APIFY_TOKEN=

# --- Paths (defaults are fine) ---
STATE_INTEL_DB=data/state_intel.db
